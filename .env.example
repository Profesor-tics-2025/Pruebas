# General
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:5173

# Database / Queue
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/video_ai
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change_me_jwt
JWT_EXPIRES_IN=1h

# Storage
UPLOAD_DIR=backend/uploads
MAX_VIDEO_MB=200

# AI Keys
OPENAI_API_KEY=
GOOGLE_CLOUD_API_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
HUGGINGFACE_API_KEY=
